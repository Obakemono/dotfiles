[colors]

background = #151515
background-alpha = #151515

background-alt = #ded0b7
background-alt-alpha = #99ded0b7

foreground = #d0d0d0

foreground-alt = #ac4142

[bar/main]
width = 90%
height = 30
fixed-center = true

background = ${colors.background-alpha}
foreground = ${colors.foreground}

offset-x = 5%
offset-y = 10

line-size = 2 
line-color = ${colors.foreground}

padding-left = 1 
padding-right = 2

module-margin-left = 1 
module-margin-right = 1 

font-0 = Source Code Pro:style=Medium:pixelsize=12;3
font-1 = Unifont:style=Regular:size=16;3
font-2 = siji:pixelsize=16;3
font-3 = Font Awesome 5 Free,Font Awesome 5 Free Solid:style=Solid:size=14;3

modules-left = bspwm
modules-center =
modules-right = pulseaudio wlan eth battery date xkeyboard powermenu

tray-position = center
tray-padding = 2

cursor-click = pointer
cursor-scroll = ns-resize

[module/xwindow]
type = internal/xwindow
label = %title:0:30:...%

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

format-prefix = "ÔĄú "
format-prefix-foreground = ${colors.foreground-alt}

label-layout = %layout%

label-indicator-underline = ${colors.foreground}

[module/bspwm]
type = internal/bspwm

label-focused = %icon%
label-focused-foreground = ${colors.foreground-alt}
label-focused-underline = ${colors.foreground-alt}
label-focused-padding = 1

label-occupied = %icon%
label-occupied-foreground = ${colors.foreground-alt}
label-occupied-padding = 1

label-urgent = %icon%!
label-urgent-padding = 1

label-empty = %icon%
label-empty-padding = 1

ws-icon-0 = I;ÔČô
ws-icon-1 = II;ÔēĄ
ws-icon-2 = III;ÔďĽ
ws-icon-3 = IV;ÔĚď

[module/mpd]
type = internal/mpd
format-online = <label-song>  <icon-prev> <icon-stop> <toggle> <icon-next>

icon-prev = ÓāĖ
icon-stop = Óāô
icon-play = Óāö
icon-pause = Óāõ
icon-next = Óāú

label-song-maxlen = 25
label-song-ellipsis = true

[module/xbacklight]
type = internal/xbacklight

format = <label> <bar>
label = BL

bar-width = 10
bar-indicator = |
bar-indicator-foreground = #fff
bar-indicator-font = 2
bar-fill = ‚ĒÄ
bar-fill-font = 2
bar-fill-foreground = #9f78e1
bar-empty = ‚ĒÄ
bar-empty-font = 2
bar-empty-foreground = ${colors.foreground-alt}

[module/backlight-acpi]
inherit = module/xbacklight
type = internal/backlight
card = intel_backlight

[module/wlan]
type = internal/network
interface = wlp6s0
interval = 3.0

format-connected = %{A1:urxvt -e nmtui &:}<label-connected>%{A}
label-connected = "%essid%"
format-connected-prefix = "Ôáę "
format-connected-prefix-foreground = ${colors.background-alt}
format-connected-padding = 1

format-disconnected = %{A1:urxvt -e nmtui &:}<label-disconnected>%{A}
label-disconnected = "disconnected"
format-disconnected-prefix = "Ôáę "

;ramp-signal-0 = Óąė
;ramp-signal-1 = Óąô
;ramp-signal-2 = Óąö
;ramp-signal-3 = Óąö
;ramp-signal-4 = Óąö
;ramp-signal-foreground = ${colors.foreground-alt}

[module/eth]
type = internal/network
interface = enp5s0f2
interval = 3.0

format-connected-prefix = "ÔõŅ "
format-connected-prefix-foreground = ${colors.foreground-alt}
label-connected = %{A1:urxvt -e nmtui &:}%local_ip%%{A}

format-disconnected = <label-disconnected>
format-disconnected-prefix = "ÔõŅ "
label-disconnected = "disconnected"

[module/date]
type = internal/date
interval = 5

date =
date-alt = " %Y-%m-%d"

time = %H:%M
time-alt = %H:%M:%S

format-prefix = ÔÄó
format-prefix-foreground= ${colors.foreground-alt}

label = %date% %time%

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <label-volume>
label-volume = "%percentage%%"
format-volume-prefix= "ÔÄ® "
format-volume-prefix-foreground = ${colors.foreground-alt}

label-muted = muted
format-muted-prefix = "Ôö© "

[module/alsa]
type = internal/alsa

format-volume = <label-volume> <bar-volume>
label-volume = VOL
label-volume-foreground = ${root.foreground}

format-muted-prefix = "Óąā "
format-muted-foreground = ${colors.foreground-alt}
label-muted = sound muted

bar-volume-width = 10
bar-volume-foreground-0 = #55aa55
bar-volume-foreground-1 = #55aa55
bar-volume-foreground-2 = #55aa55
bar-volume-foreground-3 = #55aa55
bar-volume-foreground-4 = #55aa55
bar-volume-foreground-5 = #f5a70a
bar-volume-foreground-6 = #ff5555
bar-volume-gradient = false
bar-volume-indicator = |
bar-volume-indicator-font = 2
bar-volume-fill = ‚ĒÄ
bar-volume-fill-font = 2
bar-volume-empty = ‚ĒÄ
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground-alt}

[module/battery]
type = internal/battery
battery = BAT0
adapter = ADP1
full-at = 98

format-charging = <animation-charging> <label-charging>

format-discharging = <animation-discharging> <label-discharging>

format-full-prefix = "Óąļ "

ramp-capacity-0 = Óą∂
ramp-capacity-1 = Óą∑
ramp-capacity-2 = Óął

animation-charging-0 = ÔČĄ
animation-charging-1 = ÔČÉ
animation-charging-2 = ÔČā
animation-charging-3 = ÔČĀ
animation-charging-4 = ÔČÄ
animation-charging-framerate = 750
animation-charging-foreground = ${colors.foreground-alt}

animation-discharging-0 = Óął
animation-discharging-1 = Óą∑
animation-discharging-2 = Óą∂
animation-discharging-framerate = 750

[module/temperature]
type = internal/temperature
thermal-zone = 0
warn-temperature = 60

format = <ramp> <label>
format-underline = #f50a4d
format-warn = <ramp> <label-warn>
format-warn-underline = ${self.format-underline}

label = %temperature-c%
label-warn = %temperature-c%
label-warn-foreground = ${colors.secondary}

ramp-0 = ÓÉČ
ramp-1 = ÓÉä
ramp-2 = ÓÉč
ramp-foreground = ${colors.foreground-alt}

[module/powermenu]
type = custom/menu

expand-right = true
format-spacing = 1

label-open = ÔÄĎ
label-close = ÔÉĘ cancel
label-separator = |

label-open-foreground = ${colors.foreground-alt}
label-close-foreground = ${colors.foreground-alt}
label-separator-foreground = ${colors.foreground-alt}

menu-0-0 = reboot
menu-0-0-exec = systemctl reboot
menu-0-1 = power off
menu-0-1-exec = systemctl poweroff

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
;pseudo-transparency = false

[global/wm]
margin-top = 5
margin-bottom = 5

